# Copy this file to .env.local and fill in your actual credentials.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ENCRYPTION_KEY=

# PayMongo — leave unset to run payments in stub mode (no real gateway).
# When PAYMONGO_SECRET_KEY is present, real PayMongo links are created.
PAYMONGO_SECRET_KEY=sk_test_your-secret-key-here
PAYMONGO_WEBHOOK_SECRET=whsk_your-webhook-signing-secret-here

DIALOGFLOW_PROJECT_ID="your-project-id-from-json"
DIALOGFLOW_AGENT_ID="your-agent-id-from-cx-url"
DIALOGFLOW_LOCATION="global"
DIALOGFLOW_CLIENT_EMAIL="your-service-account-email"
DIALOGFLOW_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourKeyHere...\n-----END PRIVATE KEY-----\n"

# Resend — leave unset to run in stub mode (links logged to console, no real email sent).
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL="AppointDent <noreply@yourdomain.com>"
NEXT_PUBLIC_SITE_URL=http://localhost:3000
